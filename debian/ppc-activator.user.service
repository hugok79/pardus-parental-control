[Unit]
Description=Pardus Parental Control - Activator Service
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=exec
Restart=no
Slice=app.slice
ExecStart=/usr/bin/pkexec /usr/share/pardus/pardus-parental-control/src/PPCActivator.py %U %u

[Install]
WantedBy=graphical-session.target
